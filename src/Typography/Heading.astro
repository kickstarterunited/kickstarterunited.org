---
interface Props {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  size?: "xl" | "lg" | "md" | "sm";
  maxLineLength?: boolean | number;
  [key: string]: any;
}

const { as: Tag, size = "lg", maxLineLength = true, class: cls, style: userStyle, ...attrs } = Astro.props;

const lineLengthValue =
  maxLineLength === false ? "none" : maxLineLength === true ? "25ch" : `${maxLineLength}ch`;

const styleStr = [
  `--type-max-line-length:${lineLengthValue}`,
  userStyle,
].filter(Boolean).join(";");
---

<Tag class:list={[`heading-${size}`, cls]} style={styleStr} {...attrs}><slot /></Tag>

<style is:global>
  @layer components {
    .heading-xl,
    .prose h1 {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-xl);
      line-height: 1.1;
      letter-spacing: 0.02em;
      font-weight: 700;
      text-wrap: pretty;
      max-inline-size: var(--type-max-line-length, none);
    }

    .heading-lg,
    .prose h2 {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-lg);
      line-height: 1.2;
      letter-spacing: 0.01em;
      font-weight: 700;
      text-wrap: pretty;
      max-inline-size: var(--type-max-line-length, none);
    }

    .heading-md,
    .prose h3 {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-md);
      line-height: 1.3;
      letter-spacing: 0.01em;
      font-weight: 700;
      text-wrap: pretty;
      max-inline-size: var(--type-max-line-length, none);
    }

    .heading-sm,
    .prose :is(h4, h5, h6) {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-sm);
      line-height: 1.3;
      letter-spacing: 0.01em;
      font-weight: 600;
      text-wrap: pretty;
      max-inline-size: var(--type-max-line-length, none);
    }
  }
</style>
