---
interface Props {
  as: any;
  size?: "lg" | "md" | "sm";
  maxLineLength?: boolean | number;
  [key: string]: any;
}

const { as: Tag, size = "md", maxLineLength = true, class: cls, style: userStyle, ...attrs } = Astro.props;

const lineLengthValue =
  maxLineLength === false ? "none" : maxLineLength === true ? "65ch" : `${maxLineLength}ch`;

const styleStr = [
  `--type-max-line-length:${lineLengthValue}`,
  userStyle,
].filter(Boolean).join(";");
---

<Tag class:list={[`text-${size}`, cls]} style={styleStr} {...attrs}><slot /></Tag>

<style is:global>
  @layer components {
    .text-lg,
    .prose blockquote {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-lg);
      line-height: 1.6;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }

    .text-md,
    .prose {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-md);
      line-height: 1.6;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }

    .text-sm,
    .prose small {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-sm);
      line-height: 1.5;
      letter-spacing: 0.01em;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }
  }
</style>
