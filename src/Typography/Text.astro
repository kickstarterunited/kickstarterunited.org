---
import Type from "./Type.astro";

interface Props {
  as: any;
  size?: "lg" | "md" | "sm";
  maxLineLength?: boolean | number;
  [key: string]: any;
}

const { as: Tag, size = "md", maxLineLength = true, class: cls, style: userStyle, ...attrs } = Astro.props;

const lineLengthValue =
  maxLineLength === false ? "none" : maxLineLength === true ? "65ch" : `${maxLineLength}ch`;

const styleStr = [
  `--type-max-line-length:${lineLengthValue}`,
  userStyle,
].filter(Boolean).join(";");
---

<Type as={Tag} variant={`text-${size}`} class={cls} style={styleStr} {...attrs}><slot /></Type>
