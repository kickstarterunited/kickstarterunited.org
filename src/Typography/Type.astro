---
interface Props {
  as?: any;
  variant:
    | "heading-xl"
    | "heading-lg"
    | "heading-md"
    | "heading-sm"
    | "text-lg"
    | "text-md"
    | "text-sm";
  [key: string]: any;
}

const { as: Tag = "span", variant, class: cls, ...attrs } = Astro.props;
---

<Tag class:list={[variant, cls]} {...attrs}><slot /></Tag>
