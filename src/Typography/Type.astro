---
interface Props {
  as?: any;
  variant:
    | "heading-xl"
    | "heading-lg"
    | "heading-md"
    | "heading-sm"
    | "text-lg"
    | "text-md"
    | "text-sm";
  [key: string]: any;
}

const { as: Tag = "span", variant, class: cls, ...attrs } = Astro.props;
---

<Tag class:list={[`type-${variant}`, cls]} {...attrs}><slot /></Tag>

<style is:global>
  @layer components {
    .type-heading-xl {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-xl);
      line-height: 1.1;
      letter-spacing: 0.02em;
      font-weight: 700;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-heading-lg {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-lg);
      line-height: 1.2;
      letter-spacing: 0.01em;
      font-weight: 700;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-heading-md {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-md);
      line-height: 1.3;
      letter-spacing: 0.01em;
      font-weight: 700;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-heading-sm {
      font-family: var(--ksru-font-family-heading);
      font-size: var(--ksru-text-heading-sm);
      line-height: 1.3;
      letter-spacing: 0.01em;
      font-weight: 600;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-text-lg {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-lg);
      line-height: 1.6;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-text-md {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-md);
      line-height: 1.6;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }

    .type-text-sm {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-sm);
      line-height: 1.5;
      letter-spacing: 0.01em;
      font-weight: 400;
      max-inline-size: var(--type-max-line-length, none);
    }
  }
</style>
