---
interface Props {
  as?: any;
  maxLineLength?: boolean | number;
  [key: string]: any;
}

const { as: Tag = "div", maxLineLength = true, class: cls, style: userStyle, ...attrs } = Astro.props;

const lineLengthValue =
  maxLineLength === false ? "none" : maxLineLength === true ? "65ch" : `${maxLineLength}ch`;

const styleStr = [
  `--type-max-line-length:${lineLengthValue}`,
  userStyle,
].filter(Boolean).join(";");
---

<Tag class:list={["prose", cls]} style={styleStr} {...attrs}><slot /></Tag>

<style is:global>
  @layer components {
    .prose {
      font-family: var(--ksru-font-family-body);
      font-size: var(--ksru-text-text-md);
      line-height: 1.6;
      max-inline-size: var(--type-max-line-length, none);

      & > * + * {
        margin-block-start: 1.25em;
      }

      /* Headings */

      & :is(h1, h2, h3, h4, h5, h6) {
        font-family: var(--ksru-font-family-heading);
        text-wrap: pretty;
      }

      & * + :is(h1, h2, h3, h4, h5, h6) {
        margin-block-start: 2em;
      }

      & :is(h1, h2, h3, h4, h5, h6) + * {
        margin-block-start: 0.5em;
      }

      & h1 {
        font-size: var(--ksru-text-heading-xl);
        line-height: 1.1;
        letter-spacing: 0.02em;
        font-weight: 700;
      }

      & h2 {
        font-size: var(--ksru-text-heading-lg);
        line-height: 1.2;
        letter-spacing: 0.01em;
        font-weight: 700;
      }

      & h3 {
        font-size: var(--ksru-text-heading-md);
        line-height: 1.3;
        letter-spacing: 0.01em;
        font-weight: 700;
      }

      & :is(h4, h5, h6) {
        font-size: var(--ksru-text-heading-sm);
        line-height: 1.3;
        letter-spacing: 0.01em;
        font-weight: 600;
      }

      /* Lists */

      & :is(ul, ol) {
        padding-inline-start: 1.5em;
      }

      & li + li {
        margin-block-start: 0.25em;
      }

      & li > :is(ul, ol) {
        margin-block-start: 0.25em;
      }

      /* Blockquote */

      & blockquote {
        font-size: var(--ksru-text-text-lg);
        font-style: italic;
        border-inline-start: 3px solid currentColor;
        padding-inline-start: 1em;
      }

      & blockquote > * + * {
        margin-block-start: 0.75em;
      }

      /* Inline code */

      & :not(pre) > code {
        font-size: 0.875em;
        background: color-mix(in oklch, var(--ksru-color-text) 8%, transparent);
        padding: 0.15em 0.35em;
        border-radius: 0.25em;
      }

      /* Code blocks */

      & pre {
        font-size: var(--ksru-text-text-sm);
        line-height: 1.5;
        background: color-mix(in oklch, var(--ksru-color-text) 5%, transparent);
        padding: 1em 1.25em;
        border-radius: 0.5em;
        overflow-x: auto;
      }

      & pre code {
        background: none;
        padding: 0;
        border-radius: 0;
        font-size: inherit;
      }

      /* Links */

      & a {
        color: currentColor;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 2px;
      }

      & a:hover {
        text-decoration-thickness: 3px;
      }

      /* Images */

      & img {
        max-inline-size: 100%;
        block-size: auto;
        border-radius: 0.25em;
      }

      /* Horizontal rule */

      & hr {
        border: none;
        block-size: 1px;
        background: var(--ksru-color-border);
        margin-block: 2em;
      }

      /* Tables */

      & table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--ksru-text-text-sm);
      }

      & :is(th, td) {
        padding: 0.5em 0.75em;
        border-block-end: 1px solid var(--ksru-color-border);
        text-align: start;
      }

      & th {
        font-weight: 600;
      }

      /* Small text */

      & small {
        font-size: var(--ksru-text-text-sm);
      }

      /* Strong / emphasis inherit correctly by default */

      & strong {
        font-weight: 600;
      }
    }
  }
</style>
