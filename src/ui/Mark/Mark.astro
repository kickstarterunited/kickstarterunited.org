---
import "./mark.css";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"mark"> {
  variant?: "amber" | "emerald" | "cyan" | "brown" | "neutral" | "red";
  color?: string;
}

const { variant, color, class: cls, ...attrs } = Astro.props;
---

<mark
  class:list={["mark", cls]}
  data-mark={variant}
  style={color ? `--mark-color: ${color}` : undefined}
  {...attrs}><slot /></mark
>
