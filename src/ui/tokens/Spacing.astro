---
const steps = [
	{ token: '--ksru-space-1', step: '1', px: '4',  rem: '0.25', use: 'Micro: icon gaps, tight pairs' },
	{ token: '--ksru-space-2', step: '2', px: '8',  rem: '0.5',  use: 'Small: chip padding, inline gaps' },
	{ token: '--ksru-space-3', step: '3', px: '12', rem: '0.75', use: 'Medium: input padding, card gaps' },
	{ token: '--ksru-space-4', step: '4', px: '16', rem: '1',    use: 'Base: standard padding & gaps' },
	{ token: '--ksru-space-5', step: '5', px: '24', rem: '1.5',  use: 'Generous: card padding, group gaps' },
	{ token: '--ksru-space-6', step: '6', px: '32', rem: '2',    use: 'Section: content block spacing' },
	{ token: '--ksru-space-7', step: '7', px: '48', rem: '3',    use: 'Large: section separation' },
	{ token: '--ksru-space-8', step: '8', px: '64', rem: '4',    use: 'XL: major section breaks' },
	{ token: '--ksru-space-9', step: '9', px: '96', rem: '6',    use: 'Hero: page-level whitespace' },
];
---

<div class="spacing-demo">
	<p class="description">
		A 4px-based, 9-step spacing scale. Steps 1-4 match Tailwind defaults exactly.
		Use via CSS tokens (<code>var(--ksru-space-4)</code>) or Tailwind utilities (<code>p-4</code>, <code>gap-7</code>, etc).
	</p>

	<div class="scale">
		{steps.map(({ token, step, px, rem, use }) => (
			<div class="step">
				<div class="step__bar" style={`width: var(${token})`} />
				<div class="step__info">
					<div class="step__header">
						<strong class="step__name">{step}</strong>
						<code class="step__token">{token}</code>
					</div>
					<span class="step__values">{px}px / {rem}rem</span>
					<span class="step__use">{use}</span>
				</div>
			</div>
		))}
	</div>

	<section class="tailwind-map">
		<h3 class="section-heading">Tailwind Mapping</h3>
		<p class="description">
			The default Tailwind spacing scale is replaced. Only these values are available:
		</p>
		<div class="utility-grid">
			<code class="utility-header">Utility</code>
			<code class="utility-header">Value</code>
			<code>p-0, gap-0</code><span>0px</span>
			<code>p-px, gap-px</code><span>1px</span>
			{steps.map(({ step, px }) => (
				<>
					<code>p-{step}, gap-{step}</code>
					<span>{px}px</span>
				</>
			))}
		</div>
	</section>
</div>

<style>
	.spacing-demo {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		width: 100%;
		max-width: 800px;
		font-family: system-ui, sans-serif;
	}

	.description {
		font-size: 0.875rem;
		color: var(--ksru-color-text-secondary);
		margin: 0;
	}

	.description code {
		font-size: 0.8125rem;
		background: color-mix(in oklch, currentColor, transparent 90%);
		padding: 0.1em 0.4em;
		border-radius: 4px;
	}

	.section-heading {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--ksru-color-text-secondary);
		margin-bottom: 0.75rem;
	}

	/* ── Scale visualization ── */
	.scale {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.step {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.step__bar {
		flex-shrink: 0;
		height: 2rem;
		min-width: 4px;
		background: var(--ksru-color-accent);
		border-radius: 4px;
		transition: width 0.3s ease;
	}

	@supports (corner-shape: squircle) {
		.step__bar {
			corner-shape: squircle;
			border-radius: 16px;
		}
	}

	.step__info {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		min-width: 0;
	}

	.step__header {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
	}

	.step__name {
		font-size: 1rem;
		font-variant-numeric: tabular-nums;
		color: var(--ksru-color-text);
	}

	.step__token {
		font-size: 0.7rem;
		color: var(--ksru-color-text-secondary);
	}

	.step__values {
		font-size: 0.75rem;
		font-variant-numeric: tabular-nums;
		color: var(--ksru-color-text-secondary);
	}

	.step__use {
		font-size: 0.75rem;
		color: var(--ksru-color-text-secondary);
		opacity: 0.75;
	}

	/* ── Tailwind mapping table ── */
	.tailwind-map {
		border-top: 1px solid var(--ksru-color-border);
		padding-top: 1.5rem;
	}

	.utility-grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.25rem 1.5rem;
		font-size: 0.8125rem;
		align-items: baseline;
	}

	.utility-grid code {
		font-size: 0.75rem;
		color: var(--ksru-color-text);
	}

	.utility-grid span {
		font-variant-numeric: tabular-nums;
		color: var(--ksru-color-text-secondary);
	}

	.utility-header {
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--ksru-color-text-secondary) !important;
		font-size: 0.625rem !important;
		padding-bottom: 0.25rem;
		border-bottom: 1px solid var(--ksru-color-border);
	}
</style>
