---
import SocialLinks from "../components/SocialLinks/SocialLinks.astro";
import "../styles/global.css";
import Nav from "../components/Nav/Nav.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<html
  lang="en"
  data-wf-page="5ce75a59757fff6268d29f8b"
  data-wf-site="5ce75a58757fffbe19d29f88"
>
  <head>
    <meta charset="utf-8" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} – ` : ""} Kickstarter United</title>
    <meta content="Kickstarter United" property="og:title" />
    <meta content="/images/logo.svg" property="og:image" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="true"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Libre+Franklin:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <link rel="shortcut icon" type="image/svg+xml" href="/images/logo.svg" />

    <script src="../scripts/popover.js"></script>
    <script>
      import "invokers-polyfill";
    </script>
    <script>
      if (!("anchorName" in document.documentElement.style)) {
        import("@oddbird/css-anchor-positioning");
      }
    </script>
  </head>
  <body class="leading-[1.6]">
    <div class="page page-grid">
      <header class="page__header page-grid__bleed">
        <p class="page__logo retro-ribbon retro-ribbon--end">
          <a class="link--standalone" href="/">Kickstarter United</a>
        </p>

        <Nav />
      </header>

      <main class="page__content mx-0 my-8" id="content">
        <slot />
      </main>

      <footer class="page__footer page-grid__bleed">
        <div class="page__footer-social">
          <SocialLinks />
        </div>
        <p class="page__footer-info retro-ribbon retro-ribbon--start">
          © Copyright 2025 Kickstarter United
        </p>
      </footer>
    </div>
  </body>
</html>

<style>
  /* MARK: .retro-ribbon */
  .retro-ribbon {
    flex: 1 0 auto;
    --_padding-block: 1.25rem;
    --_height: calc(1lh + var(--_padding-block) * 2);
    padding-block: var(--_padding-block);

    text-transform: uppercase;
    letter-spacing: 0.03em;

    background-color: var(--_stop-3);
    color: white;

    --_stop-1: var(--ksru-color-accent-light);
    --_stop-2: color-mix(in oklch, var(--_stop-1), var(--_stop-4) 33%);
    --_stop-3: color-mix(in oklch, var(--_stop-1), var(--_stop-4) 66%);
    --_stop-4: var(--ksru-color-accent);

    position: relative;
    isolation: isolate;

    &::before,
    &::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      border-radius: inherit;
      corner-shape: inherit;
    }

    &::after {
      background-color: var(--_stop-1);
    }

    &::before {
      background-color: var(--_stop-2);
    }
  }

  .retro-ribbon--end {
    --_band-size: 2lh;
    padding-inline-start: 1rem;
    padding-inline-end: var(--_height);
    border-bottom-right-radius: calc(infinity * 1px);

    &::after { inset-inline-end: calc(var(--_band-size) * 2); }
    &::before { inset-inline-end: var(--_band-size); }
  }

  .retro-ribbon--start {
    --_band-size: 1lh;
    padding-inline-end: 1rem;
    padding-inline-start: var(--_height);
    border-top-left-radius: calc(infinity * 1px);
    text-align: right;

    &::after { inset-inline-start: calc(var(--_band-size) * 2); }
    &::before { inset-inline-start: var(--_band-size); }
  }
</style>
