---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../images/logo.svg";
import Carousel from "../components/Carousel/Carousel.astro";
import CarouselItem from "../components/Carousel/CarouselItem.astro";
import UrgentBanner from "../components/UrgentBanner/UrgentBanner.astro";

// Rally times (all ET on Feb 27, 2026)
const RALLY_START  = "2026-02-27T17:00:00Z"; // noon ET = 5pm UTC
const RALLY_CUTOFF = "2026-02-27T18:00:00Z"; // 1pm ET  = 6pm UTC
const showRally = Date.now() < new Date(RALLY_CUTOFF).getTime();

function getBadge(now: number) {
  const start = new Date(RALLY_START).getTime();
  const end   = new Date(RALLY_CUTOFF).getTime();
  if (now >= start && now < end) return "RIGHT NOW";
  // Midnight ET on rally day = 5am UTC
  const dayStart = new Date("2026-02-27T05:00:00Z").getTime();
  if (now >= dayStart && now < start) return "TODAY";
  return "TOMORROW";
}
---

<BaseLayout title="Home">
  {showRally && (
    <UrgentBanner badge={getBadge(Date.now())} id="rally" data-start={RALLY_START} data-cutoff={RALLY_CUTOFF} class="mt-[calc(-2rem+2px)]">
      <h1><span class="highlight">Rally to End Retaliation</span></h1>
      <p>
        On February 11, Kickstarter management terminated bargaining unit members
        and forced others out, <strong>targeting strike leaders and union
        activists</strong>, just 3 months after workers ratified a <a href="/contracts/2025">historic contract</a>
        following a 42-day strike!
      </p>
      <p>
        Join us at a <strong>virtual rally</strong> to demand reinstatement and an
        end to retaliation.
      </p>
      <div class="urgent-banner__when">
        <dl>
          <dt>When</dt>
          <dd>Thursday, February 27 at noon ET / 9am Pacific</dd>
          <dt>Where</dt>
          <dd>Virtual (Zoom)</dd>
        </dl>
      </div>
      <p class="mt-4">
        <a href="/rally" class="btn btn-success urgent-banner__cta">Register for the Rally</a>
      </p>
      <div class="urgent-banner__actions">
        <a href="/petition" class="btn btn-info">Sign the Petition</a>
        <a href="mailto:e@kickstarter.com" class="btn btn-info">Email the CEO</a>
      </div>
    </UrgentBanner>
  )}

  <script>
    const rally = document.getElementById("rally");
    if (rally) {
      const start  = new Date(rally.dataset.start!).getTime();
      const cutoff = new Date(rally.dataset.cutoff!).getTime();
      const badge  = rally.querySelector(".urgent-banner__badge");
      const now = Date.now();

      if (now >= cutoff) { rally.remove(); }
      else {
        // Midnight ET on rally day
        const dayStart = new Date("2026-02-27T05:00:00Z").getTime();

        function updateBadge() {
          if (!badge) return;
          const t = Date.now();
          if (t >= start)         badge.textContent = "RIGHT NOW";
          else if (t >= dayStart) badge.textContent = "TODAY";
          else                    badge.textContent = "TOMORROW";
        }

        updateBadge();

        // Schedule transitions
        if (now < dayStart) setTimeout(() => { updateBadge(); }, dayStart - now);
        if (now < start)    setTimeout(() => { updateBadge(); }, start - now);
        setTimeout(() => rally.remove(), cutoff - now);
      }
    }
  </script>

  <Logo class="mx-auto mt-24" width={256} height={256} />

  <hr />

  <div>
    <div class="surface breaking">
      <h1 class="heading-3">Kickstarter United Prevails!</h1>

      <p>
        After <strong>7 months</strong> of bargaining and <strong>42</strong> days
        of striking, Kickstarter United has voted to end the strike after <strong
        >
          securing historic protections
        </strong> for our union. When we fight, we win! Here’s what we won together:
      </p>
      <ul>
        <li>
          <a href="#four-day-workweek"
            ><strong>Extremely strong protections codified</strong> for our Four-Day
            Workweek</a
          >
        </li>
        <li>
          <a href="#minimum-salary-floor"
            ><strong>Improving pay equity</strong> by establishing a salary floor,
            with a bonus for our most undervalued workers</a
          >
        </li>
        <li>
          <a href="#much-more">
            Protections for workers in a world with <strong
              >generative AI</strong
            >
          </a>
        </li>
        <li><strong>Much more!</strong></li>
      </ul>

    </div>

    <Carousel class="mt-8 p-2" forceSnap inertItems scrollButtons scrollMarkers>
      <CarouselItem id="four-day-workweek" itemLabel="Four-Day Workweek">
        <div class="surface">
          <h2>Codified Four-Day Workweek!</h2>
          <p>
            We have <strong>codified our Four-Day Workweek</strong>, with strong
            protections if management tries to force us to revert to a five-day
            workweek.
          </p>
          <ul>
            <li>
              Temporary changes to Five-Day Workweek <strong>must</strong> be justified,
              with notice in advance, and a time limit
            </li>
            <li>
              Permanent changes to Five-Day Workweek <strong>must</strong> involve
              bargaining with the union
            </li>
            <li>
              If management tries to force it anyway, <strong
                >we can strike</strong
              >
            </li>
          </ul>
        </div>
      </CarouselItem>

      <CarouselItem id="minimum-salary-floor" itemLabel="Minimum Salary Floor">
        <div class="surface">
          <h2>Raising the minimum salary floor!</h2>
          <p>
            The market undervalues some of our most vital workers, and we won
            strong provisions to <strong
              >raise their minimum salary floor</strong
            >
            considerably!
          </p>
          <ul>
            <li>
              An <strong>escalating increase</strong> in the pay floor based on cost
              of living, an <strong>average 6% increase</strong> to our most undervalued
              workers
            </li>
            <li>A one-time $6,000 bonus for the most undervalued workers</li>
            <li>
              Yearly national benchmarking to push pay upwards <strong
                >across the whole unit</strong
              >
            </li>
          </ul>
        </div>
      </CarouselItem>

      <CarouselItem id="much-more" itemLabel="Much, much more!">
        <div class="surface">
          <h2>Much, much more!</h2>

          <p>
            We won many improvements to our working conditions with <strong
              >no regressions</strong
            > in our worker protections!
          </p>
          <ul>
            <li>
              Cannot replace a role with AI, and management must work with
              employees if AI changes a role
            </li>
            <li>
              Strong protections against replacing full time employees with
              contractors
            </li>
            <li>
              More input from employees with a regular forum for business
              operations
            </li>
          </ul>
        </div>
      </CarouselItem>
    </Carousel>

    <p class="mt-8">
      <strong>Thank you</strong> to everyone who showed support, wrote emails to
      leadership, donated to our strike fund, and came to our pickets. <strong>
        When we fight, we win!
      </strong>
    </p>
    <div class="text-center my-8">
      <script async data-uid="c936d588a0" src="https://kickstarter-united.kit.com/c936d588a0/index.js"></script>
    </div>
  </div>
</BaseLayout>
