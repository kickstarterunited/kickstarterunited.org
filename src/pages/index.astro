---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../images/logo.svg";
import WeWon from "../images/2025_contract/we-won.png";
import UrgentBanner from "../components/UrgentBanner/UrgentBanner.astro";
import { Icon } from "astro-icon/components";
import "../ui/SocialLinks/social-links.css";
import Mark from "../ui/Mark/Mark.astro";


import { allBlogPosts } from "../blog/getBlogPosts";
import { redirects } from "../data/redirects";

const showBanner = true;
const hasBlogPosts = allBlogPosts.length > 0;
const hasPetition = "/petition" in redirects;
---

<BaseLayout title="Home">
  {
    showBanner && (
      <UrgentBanner badge="TAKE ACTION" class="page-grid--subgrid -mt-xl">
        <h1 data-theme="inverse">
          <Mark>Stop the Retaliation</Mark>
        </h1>
        <p>
          On February 11, Kickstarter management terminated bargaining unit
          members and forced others out,{" "}
          <strong>targeting strike leaders and union activists</strong>, just 3
          months after workers ratified a{" "}
          <a href="/contracts/2025">historic contract</a>
          following a 42-day strike.
        </p>
        <p>
          Are you also pissed? <strong>Here's what you can do to help:</strong>
        </p>
        <p class="mt-md">
          <a href="/petition" class="btn btn-success urgent-banner__cta">
            Sign Our Letter
          </a>
        </p>
        <div class="urgent-banner__actions">
          <a href="mailto:e@kickstarter.com" class="btn btn-info">
            Write to the CEO
          </a>
        </div>
        <p class="mt-md mb-0 opacity-85">Follow along:</p>
        <div
          class="urgent-banner__actions"
          style="margin-top: var(--ksru-space-xs);"
        >
          <a
            href="https://www.instagram.com/kickstarter_united"
            target="_blank"
            rel="me noopener noreferrer"
            class="btn social-link__btn social-link__btn--labeled"
          >
            <>
              <Icon name="tabler:brand-instagram" size={24} />
              <span>Instagram</span>
            </>
          </a>
          <a
            href="https://bsky.app/profile/kickstarterunited.org"
            target="_blank"
            rel="me noopener noreferrer"
            class="btn social-link__btn social-link__btn--labeled"
          >
            <>
              <Icon name="tabler:brand-bluesky" size={24} />
              <span>Bluesky</span>
            </>
          </a>
          <a
            href="https://www.facebook.com/KickstarterUnited"
            target="_blank"
            rel="me noopener noreferrer"
            class="btn social-link__btn social-link__btn--labeled"
          >
            <>
              <Icon name="tabler:brand-facebook" size={24} />
              <span>Facebook</span>
            </>
          </a>
          <a
            href="https://www.linkedin.com/in/kickstarter-united-4924ba37b/"
            target="_blank"
            rel="me noopener noreferrer"
            class="btn social-link__btn social-link__btn--labeled"
          >
            <>
              <Icon name="tabler:brand-linkedin" size={24} />
              <span>LinkedIn</span>
            </>
          </a>
        </div>
      </UrgentBanner>
    )
  }

  <section class="hero col-[wide]">
    <Logo class="hero__logo" width={96} height={96} />
    <h1 class="hero__headline">We are Kickstarter United</h1>
    <p class="hero__subtitle">
      Fair pay. Job protections. A four-day workweek. <strong
        >We won it all.</strong
      >
    </p>
  </section>

  <!-- ═══ RALLY VIDEO ════════════════════════════════════════════════════ -->
  <section class="rally-video page-grid--subgrid">
    <h2 class="rally-video__heading">
      <Icon name="tabler:video" class="rally-video__icon" />
      Watch our rally to end retaliation
    </h2>
    <div class="rally-video__embed col-[wide]">
      <iframe
        src="https://www.youtube-nocookie.com/embed/kGBHA8Cs7uI"
        title="Kickstarter United - Rally to End Retaliation | Feb 27, 2026"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
        loading="lazy"></iframe>
    </div>
    <p class="rally-video__caption">
      On February 27, Kickstarter United rallied to demand an end to
      management's retaliation against union workers.
    </p>
  </section>

  <!-- ═══ AUDIENCE PATHWAY CARDS ═════════════════════════════════════════ -->
  <section class="paths">
    <h2 class="paths__heading">I'm here because...</h2>
    <div class="paths__grid">
      <div class="paths__card paths__card--worker">
        <h3 class="paths__title">
          <span class="action-badge"
            ><Icon name="tabler:briefcase" class="action-icon" /></span
          >I'm a worker
        </h3>
        <p>
          Learn about our union and what we've won for Kickstarter employees.
        </p>
        <div class="paths__links">
          <a href="/about">About</a>
          <a href="/contracts/2025">2025 Contract</a>
          <a href="/faq">FAQ</a>
        </div>
      </div>

      <div class="paths__card paths__card--creator">
        <h3 class="paths__title">
          <span class="action-badge"
            ><Icon name="tabler:heart-handshake" class="action-icon" /></span
          >I'm a creator
        </h3>
        <p>Find out how creators can support the people behind the platform.</p>
        <div class="paths__links">
          <a href="/creators">Creators</a>
          <a href="/faq">FAQ</a>
          <a href="/socials">Socials</a>
        </div>
      </div>

      <div class="paths__card paths__card--media">
        <h3 class="paths__title">
          <span class="action-badge"
            ><Icon name="tabler:broadcast" class="action-icon" /></span
          >I'm press / media
        </h3>
        <p>Get the story on one of tech's most prominent labor unions.</p>
        <div class="paths__links">
          <a href="/press">Press</a>
          <a href="/about">About</a>
          {hasBlogPosts && <a href="/blog">Blog</a>}
        </div>
      </div>

      <div class="paths__card paths__card--supporter">
        <h3 class="paths__title">
          <span class="action-badge"
            ><Icon name="tabler:hand-love-you" class="action-icon" /></span
          >I'm a supporter
        </h3>
        <p>
          Stand with us - sign our petition, stay updated, read our contract.
        </p>
        <div class="paths__links">
          {hasPetition && <a href="/petition">Petition</a>}
          <a href="#email-signup">Email Updates</a>
          <a href="/contracts/2025">Contract</a>
        </div>
      </div>
    </div>
  </section>

  <div class="prevails col-[wide]">
    <div class="card-surface breaking">
      <h1 class="heading-3">Kickstarter United Prevails!</h1>

      <p>
        After <strong>7 months</strong> of bargaining and <strong>42</strong> days
        of striking, Kickstarter United has voted to end the strike after <strong
        >
          securing historic protections
        </strong> for our union. When we fight, we win! Here’s what we won together:
      </p>
      <ul>
        <li>
          <a href="#four-day-workweek"
            ><strong>Extremely strong protections codified</strong> for our Four-Day
            Workweek</a
          >
        </li>
        <li>
          <a href="#minimum-salary-floor"
            ><strong>Improving pay equity</strong> by establishing a salary floor,
            with a bonus for our most undervalued workers</a
          >
        </li>
        <li>
          <a href="#much-more">
            Protections for workers in a world with <strong
              >generative AI</strong
            >
          </a>
        </li>
        <li><strong>Much more!</strong></li>
      </ul>
    </div>
    <div class="prevails__photo-wrap">
      <Image
        class="prevails__photo"
        alt="A screenshot of a Zoom meeting where our Bargaining Unit members were celebrating their new contract and the conclusion of their strike"
        src={WeWon}
      />
    </div>
  </div>

  <div class="wins card-surface mt-xl text-pretty">
    <details class="wins__item" open id="four-day-workweek">
      <summary
        ><Icon name="tabler:calendar-check" class="wins__icon" />Codified
        Four-Day Workweek!</summary
      >
      <div class="wins__body">
        <p>
          We have <strong>codified our Four-Day Workweek</strong>, with strong
          protections if management tries to force us to revert to a five-day
          workweek.
        </p>
        <ul>
          <li>
            <Icon name="tabler:clock-shield" class="wins__bullet-icon" />
            <span
              >Temporary changes to Five-Day Workweek <strong>must</strong> be justified,
              with notice in advance, and a time limit</span
            >
          </li>
          <li>
            <Icon name="tabler:scale" class="wins__bullet-icon" />
            <span
              >Permanent changes to Five-Day Workweek <strong>must</strong> involve
              bargaining with the union</span
            >
          </li>
          <li>
            <Icon name="tabler:gavel" class="wins__bullet-icon" />
            <span
              >If management tries to force it anyway, <strong
                >we can strike</strong
              ></span
            >
          </li>
        </ul>
      </div>
    </details>

    <details class="wins__item" id="minimum-salary-floor">
      <summary
        ><Icon name="tabler:trending-up" class="wins__icon" />Raising the
        minimum salary floor!</summary
      >
      <div class="wins__body">
        <p>
          The market undervalues some of our most vital workers, and we won
          strong provisions to <strong>raise their minimum salary floor</strong>
          considerably!
        </p>
        <ul>
          <li>
            <Icon
              name="tabler:chart-arrows-vertical"
              class="wins__bullet-icon"
            />
            <span
              >An <strong>escalating increase</strong> in the pay floor based on cost
              of living, an <strong>average 6% increase</strong> to our most undervalued
              workers</span
            >
          </li>
          <li>
            <Icon name="tabler:coin" class="wins__bullet-icon" />
            <span>A one-time $6,000 bonus for the most undervalued workers</span
            >
          </li>
          <li>
            <Icon name="tabler:chart-bar" class="wins__bullet-icon" />
            <span
              >Yearly national benchmarking to push pay upwards <strong
                >across the whole unit</strong
              ></span
            >
          </li>
        </ul>
      </div>
    </details>

    <details class="wins__item" id="much-more">
      <summary
        ><Icon name="tabler:sparkles" class="wins__icon" />Much, much more!</summary
      >
      <div class="wins__body">
        <p>
          We won many improvements to our working conditions with <strong
            >no regressions</strong
          > in our worker protections!
        </p>
        <ul>
          <li>
            <Icon name="tabler:robot" class="wins__bullet-icon" />
            <span
              >Cannot replace a role with AI, and management must work with
              employees if AI changes a role</span
            >
          </li>
          <li>
            <Icon name="tabler:shield-check" class="wins__bullet-icon" />
            <span
              >Strong protections against replacing full time employees with
              contractors</span
            >
          </li>
          <li>
            <Icon name="tabler:messages" class="wins__bullet-icon" />
            <span
              >More input from employees with a regular forum for business
              operations</span
            >
          </li>
        </ul>
      </div>
    </details>
  </div>

  <p class="mt-2xl">
    <strong>Thank you</strong> to everyone who showed support, wrote emails to leadership,
    donated to our strike fund, and came to our pickets. <strong>
      When we fight, we win!
    </strong>
  </p>
  <div class="text-center my-2xl" id="email-signup">
    <script
      is:inline
      async
      data-uid="c936d588a0"
      src="https://kickstarter-united.kit.com/c936d588a0/index.js"></script>
  </div>
</BaseLayout>

<script>
  const wrap = document.querySelector<HTMLElement>(".prevails__photo-wrap");
  const img = wrap?.querySelector<HTMLImageElement>(".prevails__photo");

  if (wrap && img) {
    wrap.addEventListener("mousemove", (e) => {
      const rect = wrap.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      img.style.objectPosition = `${x}% ${y}%`;
    });

    wrap.addEventListener("mouseleave", () => {
      img.style.objectPosition = "";
    });
  }
</script>

<style>
  /* ═══ HERO ═══════════════════════════════════════════════════════════ */

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ksru-space-sm);
    margin-block: var(--ksru-space-3xl);
  }

  .hero__logo {
    flex-shrink: 0;
  }

  :global([data-theme="dark"]) .hero__logo {
    filter: invert(1);
  }

  @media (prefers-color-scheme: dark) {
    :global([data-theme="system"]) .hero__logo {
      filter: invert(1);
    }
  }

  .hero__headline {
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1.1;
    margin: 0;
    text-wrap: balance;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.5;
    margin-top: 0;
    color: color-mix(in oklch, currentColor, transparent 30%);
    max-width: 45ch;
    text-wrap: balance;
  }

  /* ═══ RALLY VIDEO ═══════════════════════════════════════════════════ */

  .rally-video {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding-block: var(--ksru-space-3xl);
    row-gap: var(--ksru-space-md);
    max-height: 100vh;
    border-radius: 32px;
  }

  @supports (corner-shape: squircle) {
    .rally-video {
      border-radius: 64px;
      corner-shape: squircle;
    }
  }

  .rally-video::after {
    --_emerald: color-mix(in oklch, var(--ksru-emerald-400), transparent 40%);
    --_cyan: color-mix(in oklch, var(--ksru-cyan-400), transparent 40%);
    --_amber: color-mix(in oklch, var(--ksru-amber-300), transparent 40%);

    content: "";
    position: absolute;
    inset: -40%;
    grid-column: bleed;
    background:
      radial-gradient(circle at 10% 15%, var(--_emerald) 0%, transparent 55%),
      radial-gradient(circle at 85% 35%, var(--_cyan) 0%, transparent 45%),
      radial-gradient(circle at 35% 90%, var(--_amber) 0%, transparent 50%);
    filter: blur(60px);
    z-index: 0;
  }

  .rally-video > * {
    position: relative;
    z-index: 1;
  }

  :global([data-theme="dark"]) .rally-video::after {
    --_emerald: color-mix(in oklch, var(--ksru-emerald-700), transparent 50%);
    --_cyan: color-mix(in oklch, var(--ksru-cyan-700), transparent 50%);
    --_amber: color-mix(in oklch, var(--ksru-amber-600), transparent 50%);
  }

  @media (prefers-color-scheme: dark) {
    :global([data-theme="system"]) .rally-video::after {
      --_emerald: color-mix(in oklch, var(--ksru-emerald-700), transparent 50%);
      --_cyan: color-mix(in oklch, var(--ksru-cyan-700), transparent 50%);
      --_amber: color-mix(in oklch, var(--ksru-amber-600), transparent 50%);
    }
  }

  .rally-video__heading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ksru-space-sm);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin: 0;
  }

  .rally-video__icon {
    width: 1.25em;
    height: 1.25em;
    color: var(--ksru-color-accent);
    flex-shrink: 0;
  }

  .rally-video__embed {
    width: 100%;
    max-height: 60vh;
    max-width: calc(60vh * 16 / 9);
    justify-self: center;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 4px 24px oklch(0 0 0 / 0.15),
      0 0 0 1px var(--ksru-color-border);
  }

  @supports (corner-shape: squircle) {
    .rally-video__embed {
      border-radius: 64px;
      corner-shape: squircle;
    }
  }

  .rally-video__embed iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }

  .rally-video__caption {
    font-size: 0.875rem;
    opacity: 0.65;
    max-width: 50ch;
    text-wrap: balance;
    margin: 0;
    justify-self: center;
  }

  /* ═══ PATHWAY CARDS ══════════════════════════════════════════════════ */

  .paths {
    margin-block: var(--ksru-space-3xl);
  }

  .paths__heading {
    text-align: center;
    margin-bottom: var(--ksru-space-lg);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
  }

  .paths__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--ksru-space-lg);
  }

  .paths__card {
    position: relative;
    padding: var(--ksru-space-lg) var(--ksru-space-lg) var(--ksru-space-lg)
      var(--ksru-space-xl);
    border-radius: 16px;
    background: var(--ksru-color-bg);
    border: 2px solid
      color-mix(in oklch, var(--ksru-color-accent), transparent 80%);
    border-left: 4px solid var(--ksru-color-accent);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  @supports (corner-shape: squircle) {
    .paths__card {
      border-radius: 32px;
      corner-shape: squircle;
    }
  }

  .paths__card:hover,
  .paths__card:has(:focus-visible) {
    box-shadow: 0 2px 12px color-mix(in oklch, var(--_accent), transparent 80%);
    border-color: var(--_accent);
  }

  /* Per-card accent colors */
  .paths__card--worker {
    --_accent: var(--ksru-color-accent);
  }
  .paths__card--creator {
    --_accent: var(--ksru-color-accent-light);
  }
  .paths__card--media {
    --_accent: var(--ksru-color-accent-rich);
  }
  .paths__card--supporter {
    --_accent: var(--ksru-color-accent-warm);
  }

  .paths__card {
    border-left-color: var(--_accent);
  }

  .paths__title {
    font-size: 1.125rem;
    font-family: var(--ksru-font-family-heading);
    font-weight: 700;
    color: var(--ksru-color-accent);
    margin-bottom: var(--ksru-space-xs);
  }

  .paths__card--creator .paths__title {
    color: color-mix(in oklch, var(--ksru-color-accent-light), black 20%);
  }

  .paths__card--media .paths__title {
    color: color-mix(in oklch, var(--ksru-color-accent-rich), black 30%);
  }

  .paths__card--supporter .paths__title {
    color: var(--_accent);
  }

  .paths__card p {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: var(--ksru-space-xs) 0 0;
    text-wrap: pretty;
  }

  .paths__card .action-badge {
    position: absolute;
    left: -1.25rem;
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    top: var(--ksru-space-lg);
    translate: 0 0;
    background: var(--_accent);
    border: none;
    border-radius: 50%;
  }

  .paths__card .action-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: white;
  }

  /* Pill-shaped link buttons */
  .paths__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ksru-space-sm);
    margin-top: var(--ksru-space-md);
  }

  .paths__links a {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 999px;
    background: color-mix(in oklch, var(--ksru-color-accent), transparent 90%);
    color: var(--ksru-color-accent);
    transition:
      background 150ms ease,
      color 150ms ease;
  }

  @supports (corner-shape: squircle) {
    .paths__links a {
      border-radius: 32px;
      corner-shape: squircle;
    }
  }

  .paths__links a:hover {
    background: var(--ksru-color-surface-accent);
    color: white;
  }

  @media (width < 640px) {
    .paths__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ PREVAILS ═══════════════════════════════════════════════════════ */

  .prevails {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--ksru-space-xl);
    margin-block: var(--ksru-space-3xl);
  }

  @media (width >= 768px) {
    .prevails .breaking {
      max-width: 50ch;
    }
  }

  .prevails__photo-wrap {
    overflow: hidden;
    border-radius: 16px;
  }

  @supports (corner-shape: squircle) {
    .prevails__photo-wrap {
      corner-shape: squircle;
      border-radius: 64px;
    }
  }

  .prevails__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
    transition: object-position 0.5s ease-out;
  }

  @media (width < 768px) {
    .prevails {
      grid-template-columns: 1fr;
    }

    .prevails__photo-wrap {
      max-height: 200px;
    }
  }

  .wins {
    --wins-radius: 32px;
    margin-block: var(--ksru-space-2xl);
    overflow: hidden;
    padding: 0;
  }

  .wins__item summary {
    cursor: pointer;
    padding: var(--ksru-space-md) var(--ksru-space-lg) var(--ksru-space-md)
      0.75rem;
    font-family: var(--ksru-font-family-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: white;
    background-color: light-dark(
      var(--ksru-color-surface-accent),
      var(--ksru-color-surface-secondary)
    );
    border-left: 20px solid light-dark(transparent, var(--ksru-color-accent));
    background-clip: border-box;
    border-radius: 0px;
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      border-radius 300ms ease;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Chevron indicator */
  .wins__item summary::after {
    content: "";
    width: 0.5em;
    height: 0.5em;
    border-right: 2.5px solid currentColor;
    border-bottom: 2.5px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.4s
      linear(0, 0.28, 0.74, 1.04, 1.22, 1.1, 0.97, 1.04, 1);
    flex-shrink: 0;
    margin-left: auto;
  }

  /* Hide default marker */
  .wins__item summary::marker,
  .wins__item summary::-webkit-details-marker {
    display: none;
  }

  .wins__item[open] summary {
    border-left-color: var(--ksru-color-accent-rich);
    background-color: light-dark(
      color-mix(in oklch, var(--ksru-color-surface-accent), black 15%),
      var(--ksru-color-surface-secondary)
    );
    border-radius: var(--wins-radius);
