---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../ui/typography/Heading.astro";
import Text from "../ui/typography/Text.astro";
---

<BaseLayout title="How Creators Can Help">
  <section class="creators-hero col-[wide]">
    <Heading as="h1" size="xl" maxLineLength={false}>How creators can support Kickstarter United</Heading>
    <Text as="p" size="lg" class="creators-hero__subtitle">
      Kickstarter creators are a <strong>vital</strong> part of the Kickstarter community,
      and your support helps us build a better workplace for the people <em
        >behind the platform you rely on</em
      >.
    </Text>
  </section>

  <div class="creators-actions col-[wide]">
    <div class="action-card">
      <h2>
        <span class="action-badge"
          ><Icon name="tabler:speakerphone" class="action-icon" /></span
        >Mention KSRU
      </h2>
      <p>
        Feature us in your campaign story and link to
        <a href="/">kickstarterunited.org</a>. Use
        <a href="/union-assets">our assets</a> in your thumbnail. We'll be happy to
        feature your project
        <a href="/projects-our-workers-love">here!</a>
      </p>
    </div>

    <div class="action-card">
      <h2>
        <span class="action-badge"
          ><Icon name="tabler:share" class="action-icon" /></span
        >Share
      </h2>
      <p>
        Spread our posts on <a href="/socials">social media</a> and help us get the
        word out about our union and the wins we've secured for workers.
      </p>
    </div>

    <div class="action-card">
      <h2>
        <span class="action-badge"
          ><Icon name="tabler:message-circle" class="action-icon" /></span
        >Talk about us!
      </h2>
      <p>
        Tell other creators, backers, and folks in the tech industry about
        Kickstarter United and the importance of unions in tech.
      </p>
    </div>

    <div class="action-card">
      <h2>
        <span class="action-badge"
          ><Icon name="tabler:file-text" class="action-icon" /></span
        >Check out our contract
      </h2>
      <p>
        See what we've won in our
        <a href="/contracts/2025">2025 contract</a> - and <em>share it</em>
        with workers at other companies who might be thinking about organizing.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .creators-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ksru-space-sm);
    margin-block: var(--ksru-space-2xl) var(--ksru-space-xl);
  }

  .creators-hero__subtitle {
    color: color-mix(in oklch, currentColor, transparent 30%);
    text-wrap: balance;
    margin-top: 0;
  }

  .creators-actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--ksru-space-lg);
    margin-bottom: var(--ksru-space-2xl);
  }

  .action-card {
    position: relative;
    padding: var(--ksru-space-lg) var(--ksru-space-lg) var(--ksru-space-lg) var(--ksru-space-xl);
    border-radius: 16px;
    corner-shape: squircle;
    background: var(--ksru-color-bg);
    border: 2px solid
      color-mix(in oklch, var(--ksru-color-accent), transparent 80%);
  }

  .action-badge {
    position: absolute;
    left: -1.25rem;
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    translate: 0 -15%;
    background: var(--ksru-color-bg);
    border: 2px solid
      color-mix(in oklch, var(--ksru-color-accent), transparent 80%);
    border-radius: 50%;
  }

  .action-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--ksru-color-accent);
  }

  .action-card h2 {
    font-size: 1.25rem;
    font-family: var(--ksru-font-family-heading);
    font-weight: 700;
    color: var(--ksru-color-accent);
    margin-bottom: var(--ksru-space-sm);
    text-wrap: balance;
  }

  .action-card p {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }

  @supports (corner-shape: scoop) {
    @media (width >= 640px) {
      .action-card {
        padding: var(--ksru-space-lg);
      }

      .action-card:nth-child(1) {
        padding-bottom: var(--ksru-space-lg);
        border-bottom-right-radius: 32px;
        corner-shape: round round scoop round;
      }

      .action-card:nth-child(2) {
        padding-bottom: var(--ksru-space-lg);
        border-bottom-left-radius: 32px;
        corner-shape: round round round scoop;
      }

      .action-card:nth-child(3) {
        padding-top: var(--ksru-space-lg);
        border-top-right-radius: 32px;
        corner-shape: round scoop round round;
      }

      .action-card:nth-child(4) {
        padding-top: var(--ksru-space-lg);
        border-top-left-radius: 32px;
        corner-shape: scoop round round round;
      }

      .action-badge {
        translate: none;
        width: auto;
        height: auto;
        background: none;
        border: none;
        border-radius: 0;
      }

      .action-icon {
        width: 1.5rem;
        height: 1.5rem;
      }

      .action-card:nth-child(1) .action-badge {
        left: auto;
        right: -0.5rem;
        top: auto;
        bottom: -0.5rem;
      }

      .action-card:nth-child(2) .action-badge {
        left: -0.5rem;
        top: auto;
        bottom: -0.5rem;
      }

      .action-card:nth-child(3) .action-badge {
        left: auto;
        right: -0.5rem;
        top: -0.5rem;
      }

      .action-card:nth-child(4) .action-badge {
        left: -0.5rem;
        top: -0.5rem;
      }
    }
  }

  @media (width < 640px) {
    .creators-actions {
      grid-template-columns: 1fr;
    }
  }
</style>
