---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../ui/typography/Heading.astro";
import Text from "../ui/typography/Text.astro";
import Logo from "../images/logo.svg";

const socials = [
  // as of Mar 2026: 584 followers, 99 posts, very active, created Jul 2025
  {
    name: "Bluesky",
    icon: "tabler:brand-bluesky",
    href: "https://bsky.app/profile/kickstarterunited.org",
    description:
      "Our most active platform. Union news, solidarity, and updates posted regularly.",
    color: "#0085ff",
  },
  // as of Mar 2026: 441 followers, 95 posts, very active, created Jan 2023
  {
    name: "Mastodon",
    icon: "tabler:brand-mastodon",
    href: "https://union.place/@kickstarterunited",
    description:
      "Same updates as Bluesky, on the fediverse. Hosted on union.place.",
    color: "#6364ff",
  },
  // as of Mar 2026: 596 followers, 84 posts, active
  {
    name: "Instagram",
    icon: "tabler:brand-instagram",
    href: "https://www.instagram.com/kickstarter_united",
    description:
      "Rally photos, graphics, and visual updates from union actions.",
    color: "#e4405f",
  },
  // as of Mar 2026: 262 followers, moderate activity, professional tone
  {
    name: "LinkedIn",
    icon: "tabler:brand-linkedin",
    href: "https://www.linkedin.com/in/kickstarter-united-4924ba37b/",
    description: "In-depth posts on labor in tech, with receipts.",
    color: "#0a66c2",
  },
  // as of Mar 2026: 43 followers, 4 videos, minimal activity, created Oct 2025
  {
    name: "TikTok",
    icon: "tabler:brand-tiktok",
    href: "https://www.tiktok.com/@kickstarter_united",
    description: "Short video clips from the 2025 strike.",
    color: "#fe2c55",
  },
  // as of Mar 2026: 12 subscribers, 2 videos, dormant, rally recordings only
  {
    name: "YouTube",
    icon: "tabler:brand-youtube",
    href: "https://www.youtube.com/@KickstarterUnited",
    description: "Rally recordings from the 2025 strike.",
    color: "#ff0000",
  },
  // as of Mar 2026: 40 followers, dormant since Dec 2025, no saved VODs
  {
    name: "Twitch",
    icon: "tabler:brand-twitch",
    href: "https://www.twitch.tv/kickstarterunited",
    description: "Gaming streams and virtual pickets from the 2025 strike.",
    color: "#9146ff",
  },
  // as of Mar 2026: ~4,895 followers, oldest account (Mar 2019)
  {
    name: "X / Twitter",
    icon: "tabler:brand-x",
    href: "https://twitter.com/ksr_united",
    description: "Our original account, still active for announcements.",
    color: "#000000",
  },
];
---

<BaseLayout title="Follow our Socials">
  <section class="socials-hero">
    <Logo width="88" height="88" class="socials-hero__logo" />
    <div class="socials-hero__text">
      <Heading as="h1" size="xl" maxLineLength={false}>Follow Along</Heading>
      <Text as="p" size="lg" class="socials-hero__subtitle">
        Stay in the loop on contract wins, actions, and what it takes to build a
        union in tech.
      </Text>
    </div>
  </section>

  <nav class="social-links" aria-label="Social media links">
    {
      socials.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="me noopener noreferrer"
          class="social-link"
          style={`--brand-color: ${social.color}`}
        >
          <Icon name={social.icon} size={32} class="social-link__icon" />
          <div>
            <Heading as="span" size="sm" class="social-link__name">
              {social.name}
            </Heading>
            <Text as="span" size="sm" class="social-link__desc">
              {social.description}
            </Text>
          </div>
        </a>
      ))
    }
  </nav>
</BaseLayout>

<style>
  .socials-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ksru-space-lg);
    align-items: center;
    margin-block: var(--ksru-space-2xl) var(--ksru-space-xl);
  }

  @media (width >= 640px) {
    .socials-hero {
      grid-template-columns: auto 1fr;
    }
  }

  .socials-hero__logo {
    margin-inline: auto;
  }

  :global([data-theme="dark"]) .socials-hero__logo {
    filter: invert(1);
  }

  @media (prefers-color-scheme: dark) {
    :global([data-theme="system"]) .socials-hero__logo {
      filter: invert(1);
    }
  }

  .socials-hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--ksru-space-sm);
  }

  .socials-hero__subtitle {
    color: color-mix(in oklch, currentColor, transparent 30%);
    text-wrap: pretty;
    margin-top: 0;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--ksru-space-sm);
    max-width: 28rem;
    margin-inline: auto;
    margin-bottom: var(--ksru-space-2xl);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--ksru-space-md);
    padding: var(--ksru-space-md);
    border-radius: 12px;

    @supports (corner-shape: squircle) {
      corner-shape: squircle;
      border-radius: 24px;
    }
    border: 2px solid color-mix(in oklch, currentColor 10%, transparent);
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .social-link:hover,
  .social-link:focus-visible {
    border-color: color-mix(in oklch, var(--brand-color) 40%, transparent);
  }

  .social-link:focus-visible {
    outline: 3px solid var(--ksru-color-outline, currentColor);
    outline-offset: 3px;
  }

  .social-link__name {
    display: block;
  }

  .social-link__desc {
    display: block;
    color: color-mix(in oklch, currentColor, transparent 30%);
  }

  .social-link__icon {
    flex-shrink: 0;
    transition:
      color 0.2s,
      transform 0.2s;
  }

  .social-link:hover .social-link__icon,
  .social-link:focus-visible .social-link__icon {
    color: var(--brand-color);
    transform: scale(1.15);
  }
</style>
