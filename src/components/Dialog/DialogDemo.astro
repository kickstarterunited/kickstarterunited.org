---
import Dialog from "./Dialog.astro";
import DrawerDialog from "./DrawerDialog.astro";
import DrawerMenu from "../Menu/DrawerMenu.astro";
import Button from "../Button/Button.astro";
---

<div class="grid gap-12 p-8">
  <section>
    <h3 class="mt-0">Base Dialog</h3>
    <p class="text-sm">A centered modal dialog with backdrop blur.</p>
    <Button variant="primary" command="show-modal" commandfor="demo-dialog">
      Open Dialog
    </Button>
    <Dialog id="demo-dialog">
      <div class="p-6 grid gap-4" style="max-width: 28rem;">
        <h2 class="mt-0">Dialog Title</h2>
        <p>This is a basic dialog using design system surface and text tokens. It stays readable in both light and dark contexts.</p>
        <Button variant="primary" command="close" commandfor="demo-dialog">
          Got it
        </Button>
      </div>
    </Dialog>
  </section>

  <section>
    <h3 class="mt-0">Drawer Dialog</h3>
    <p class="text-sm">Slides in from the right, used for mobile navigation.</p>
    <Button variant="primary" command="show-modal" commandfor="demo-drawer">
      Open Drawer
    </Button>
    <DrawerDialog id="demo-drawer">
      <div class="p-6 grid gap-4" style="min-width: 280px;">
        <h2 class="mt-0">Drawer Content</h2>
        <p>The drawer uses <code>data-theme="light"</code> to establish its own color context.</p>
      </div>
    </DrawerDialog>
  </section>

  <section>
    <h3 class="mt-0">Drawer Menu (as used in nav)</h3>
    <p class="text-sm">The full mobile navigation experience with flat menu items.</p>
    <Button variant="primary" command="show-modal" commandfor="demo-drawer-menu">
      Open Mobile Nav
    </Button>
    <DrawerMenu
      id="demo-drawer-menu"
      items={[
        { label: "Home", href: "#" },
        {
          id: "drawer-about",
          label: "About",
          items: [
            { label: "About Us", href: "#" },
            { label: "Oral History", href: "#" },
            { label: "Contact Us", href: "#" },
          ],
        },
        { label: "Events", href: "#" },
        {
          id: "drawer-resources",
          label: "Resources",
          items: [
            { label: "FAQ", href: "#" },
            { label: "Logo Generator", href: "#" },
            { label: "Press", href: "#" },
            { label: "Socials", href: "#" },
          ],
        },
        {
          id: "drawer-contracts",
          label: "Contracts",
          title: "Contracts & Agreements",
          items: [
            { label: "2025 Contract", href: "#" },
            { label: "2022 Contract", href: "#" },
          ],
        },
      ]}
    />
  </section>

  <section>
    <h3 class="mt-0">Inverse Context</h3>
    <p class="text-sm">Dialogs inherit the page's theme by default, but can be overridden with <code>data-theme="light"</code>, <code>"dark"</code>, or <code>"inverse"</code>.</p>
    <div
      class="p-6 rounded-2xl flex gap-4"
      data-theme="inverse"
      style="background-color: var(--ksru-color-surface);"
    >
      <Button variant="ghost" command="show-modal" commandfor="demo-dark-dialog">
        Open Dialog
      </Button>
      <Button variant="ghost" command="show-modal" commandfor="demo-dark-drawer">
        Open Drawer
      </Button>
    </div>
    <Dialog id="demo-dark-dialog" data-theme="inverse">
      <div class="p-6 grid gap-4" style="max-width: 28rem;">
        <h2 class="mt-0">Inverse Dialog</h2>
        <p>This dialog uses <code>data-theme="inverse"</code> to always render opposite to the page theme.</p>
        <Button variant="primary" command="close" commandfor="demo-dark-dialog">
          Close
        </Button>
      </div>
    </Dialog>
    <DrawerDialog id="demo-dark-drawer" data-theme="inverse">
      <div class="p-6 grid gap-4" style="min-width: 280px;">
        <h2 class="mt-0">Inverse Drawer</h2>
        <p>This drawer uses <code>data-theme="inverse"</code> to always render opposite to the page theme.</p>
      </div>
    </DrawerDialog>
  </section>
</div>
