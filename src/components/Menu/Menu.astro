---
import MenuItem, { type MenuButtonProps } from "./MenuItem.astro";
import Button from "../Button/Button.astro";

type Props = MenuButtonProps;

const { id, isFlat, label, items, title, ...divProps } = Astro.props;
---

{
  isFlat ? (
    // Render a flat menu with section labels
    <>
      <div class="menu__title">{title ?? label}</div>
      {items.map((item) => (
        <MenuItem {...item} class:list={[item.class, "menu__item"]} isFlat />
      ))}
    </>
  ) : (
    <div {...divProps}>
      <Button
        variant="ghost"
        id={`${id}-trigger`}
        style={`anchor-name: --${id}-trigger`}
        popovertarget={`${id}-links`}
      >
        {label}
      </Button>
      <div
        id={`${id}-links`}
        class="menu"
        style={`position-anchor: --${id}-trigger`}
        popover
        data-theme="light"
        aria-labelledby={`${id}-trigger`}
      >
        {items.map((item) => (
          <MenuItem
            {...item}
            class:list={[item.class, "menu__item"]}
            isFlat={isFlat ?? true}
          />
        ))}
      </div>
    </div>
  )
}

<style is:global>
  @layer components {
    .menu {
      flex-direction: column;
      corner-shape: squircle;
    }

    .menu:popover-open,
    dialog.menu[open] {
      display: flex;
    }

    .menu:popover-open {
      /* gotta undo the Popover user styles and apply anchor positioning */
      inset: auto;
      overflow: auto;
      position-area: end span-end;
      position-try-fallbacks: flip-inline;

      background: var(--ksru-color-surface);
      color: var(--ksru-color-text);
      border: 1px solid var(--ksru-color-border);
      border-radius: 1rem;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
      corner-shape: squircle;
    }

    .menu > * {
      padding: 0.5rem 1rem;
    }

    .menu__item,
    .menu__title {
      padding: 0.5rem 1rem;
    }

    .menu__title {
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.03em;
      color: var(--ksru-color-accent);
      text-transform: uppercase;
      border-bottom: 1px solid currentColor;
      padding-top: 1rem;
    }

    .menu__item {
      text-decoration: none;
      min-width: 44px;
      min-height: 44px;
      align-content: center;
      outline-offset: -4px;
    }

    .menu__item:hover,
    .menu__item:focus:focus-visible {
      background-color: var(--ksru-color-surface-hover);
    }

    .menu__item:active {
      background-color: var(--ksru-color-surface-active);
    }
  }
</style>
