---
import "./social-links.css";

interface Props {
  label: string;
  href: string;
  showLabel?: boolean;
}
const { label, href, showLabel } = Astro.props;

// Tooltip for icon-only social links using CSS anchor positioning
// (follow-the-leader pattern). All icon-only links share a single
// tooltip element (in SocialLinks.astro). JS updates text on hover/focus;
// positioning slides via anchor() + transitions. See social-links.css.
---

<li class="m-0">
  <a
    href={href}
    rel="me noopener noreferrer"
    target="_blank"
    class:list={["btn social-link__btn", { "social-link__btn--labeled": showLabel }]}
    aria-label={!showLabel ? label : undefined}
    aria-describedby={!showLabel ? "social-tooltip" : undefined}
    data-tooltip={!showLabel ? `Follow us on ${label}` : undefined}
  >
    <slot />
    {showLabel && <span>{label}</span>}
  </a>
</li>
